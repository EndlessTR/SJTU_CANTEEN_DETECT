/* 页面整体布局 */
.page-container {
  display: flex;
  flex-direction: column;
  padding: 30rpx; /* 确保页面与屏幕周围有边距 */
  background-color: #F7EAD8; /* 背景颜色 */
  flex: 1;
  box-sizing: border-box;
  overflow-y: auto; /* 允许纵向滚动 */
  min-height: 100vh; /* 至少占满视口高度 */
}

/* 确保每个表单区域之间有足够的间距 */
.form-card {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
}

/* 输入框和文本区 */
.input-group {
  margin-bottom: 20rpx;
}

.input {
  width: 100%;  /* 确保输入框占满父容器宽度 */
  padding: 20rpx;  /* 适当增加内边距 */
  border-radius: 10rpx;
  border: 1rpx solid #D1500F;
  font-size: 28rpx;  /* 增加字体大小 */
  height: 70rpx;  /* 增加高度，确保内容完整显示 */
  box-sizing: border-box;  /* 确保padding不会导致宽度溢出 */
  overflow: hidden;  /* 防止内容溢出 */
}

.textarea {
  width: 100%;
  height: 180rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  border: 1rpx solid #D1500F;
  resize: none;
}

/* 上传图片按钮 */
.btn-upload {
  width: 100%;
  background-color: #D1500F;
  color: #F7EADA;
  padding: 15rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  text-align: center;
  margin-top: 10rpx;
}

/* 图片列表区域 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  overflow-x: auto; /* 水平滚动展示多张图片 */
  padding-bottom: 10rpx;
}

.image-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 10rpx;
  overflow: hidden;
  background-color: #f5f5f5; /* 背景颜色 */
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  object-fit: cover;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 15rpx;
  padding: 5rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 发帖按钮 */
.btn-primary {
  background-color: #D1500F;
  color: #F7EADA;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 32rpx;
  width: 100%;
  text-align: center;
  margin-top: 30rpx;
  box-sizing: border-box;
}

/* 帖子列表区域 */
.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  flex-direction: row;
  height: auto;
  column-count: auto;
  column-gap: auto;
}

.post-item {
  width: 48%;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.cover-wrapper {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 133.33%;
}

.cover-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.title {
  font-size: 30rpx;
  font-weight: bold;
  margin: 10rpx;
  color: #333;
}

.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx;
  background-color: #f9f9f9;
}

.author {
  display: flex;
  align-items: center;
}

.avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.nickname {
  font-size: 24rpx;
  color: #333;
}

.likes {
  display: flex;
  align-items: center;
}

.like-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 10rpx;
}

.like-count {
  font-size: 28rpx;
  color: #666;
}

/* 适配不同尺寸屏幕 */
@media (max-width: 375rpx) {
  .form-title {
    font-size: 28rpx;
  }

  .input {
    font-size: 28rpx;
    padding: 15rpx;
    height: 70rpx;
  }

  .textarea {
    font-size: 26rpx;
    padding: 15rpx;
  }

  .btn-primary {
    font-size: 30rpx;
  }

  .title {
    font-size: 26rpx;
  }

  .like-count {
    font-size: 26rpx;
  }

  .page-container {
    padding: 20rpx;
  }

  .form-card {
    padding: 15rpx;
  }

  .btn-upload {
    font-size: 28rpx;
  }

  .post-item {
    width: 100%;
  }

  .grid {
    column-count: 1;
  }
}

/* 刷新按钮样式 */
.refresh-button {
  position: fixed;
  right: 30rpx;
  bottom: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: #D1500F;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.refresh-icon {
  width: 50rpx;
  height: 50rpx;
  
}
