/* 容器样式 */
.container {
  padding: 40rpx;
  background-color: #F7EAD8;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 标题样式 */
.title {
  font-size: 40rpx; /* 增大标题字体大小 */
  font-weight: bold;
  margin-bottom: 50rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #ddd;
  text-align: left;
  color: #D1500F; 
}

/* 评论输入提示 */
.comment-prompt {
  font-size: 32rpx; /* 提示文字大小 */
  margin-bottom: 20rpx;
  text-align: center; /* 提示文字居中对齐 */
}

/* 打星按钮 */
.star-rating {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.star-rating image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 10rpx;
}

/* 窗口名称输入框 */
.window-name-input {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  
}

.window-name-input text {
  font-size: 30rpx; /* 输入框标签字体大小 */
  margin-right: 10rpx;
}

.window-name-input input {
  flex: 1;
  height: 80rpx; /* 增大输入框高度 */
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #ccc;
  font-size: 28rpx; /* 输入框字体大小 */
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

/* 评论输入框 */
.comment-input {
  width: 100%;
  height: 250rpx; /* 增大输入框高度 */
  padding: 30rpx;
  border-radius: 16rpx;
  border: 2rpx solid #ccc;
  font-size: 32rpx; /* 输入框字体大小 */
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

.comment-input:focus {
  border-color: #D1500F;
  outline: none;
  box-shadow: 0 4rpx 15rpx rgba(255, 126, 95, 0.3);
}

/* 提交按钮 */
.submit-button {
  background-color: #D1500F;
  color: white;
  font-size: 34rpx; /* 增大按钮字体大小 */
  padding: 25rpx;
  border-radius: 36rpx;
  width: 70%;
  margin: 30rpx auto;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.2);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

/* 历史评论标题 */
.history-title {
  font-size: 36rpx; /* 增大标题字体大小 */
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
  text-align: left;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 15rpx;
}

/* 历史评论区域 */
.history-comments {
  margin-top: 40rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  width: 100%;
}

/* 评论项 */
.comment-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
  border: 2rpx solid #f0f0f0;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.comment-index {
  font-size: 28rpx; /* 序号字体大小 */
  color: #666;
  margin-bottom: 10rpx;
}

.comment-time {
  font-size: 24rpx; /* 时间字体大小 */
  color: #888;
  display: block;
  margin-bottom: 15rpx;
}

.comment-content {
  font-size: 30rpx; /* 评论内容字体大小 */
  color: #333;
  display: block;
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}

.comment-star-count {
  font-size: 28rpx; /* 星级字体大小 */
  color: #D1500F;
  margin-top: 10rpx;
  display: block;
}

/* 点赞图标 */
.like-section {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.like-section image {
  width: 30rpx;
  height: 30rpx;
  margin-right: 20rpx;
}

.like-section text {
  font-size: 28rpx; /* 点赞数字体大小 */
}

